---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'お問い合わせ',
  description: 'AIマッチエージェントへのお問い合わせはこちらから。',
};
---

<BaseLayout 
  title="お問い合わせ" 
  description="AIマッチエージェントへのお問い合わせはこちらから。サービスに関するご質問やパートナー掲載のご相談を受け付けています。"
  jsonLd={jsonLd}
>
  <Header />
  
  <main class="py-16">
    <div class="max-w-2xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          お問い合わせ
        </h1>
        <p class="text-gray-600">
          サービスに関するご質問や、パートナー掲載のご相談など、
          お気軽にお問い合わせください。
        </p>
      </div>

      <form 
        action="/api/contact"
        method="POST"
        class="bg-white p-8 rounded-xl border border-gray-200 shadow-sm space-y-6"
      >
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
            お名前 <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
            メールアドレス <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>

        <div>
          <label for="company" class="block text-sm font-medium text-gray-700 mb-2">
            会社名
          </label>
          <input
            type="text"
            id="company"
            name="company"
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>

        <div>
          <label for="type" class="block text-sm font-medium text-gray-700 mb-2">
            お問い合わせ種別 <span class="text-red-500">*</span>
          </label>
          <select
            id="type"
            name="type"
            required
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          >
            <option value="">選択してください</option>
            <option value="service">サービスについて</option>
            <option value="partner">パートナー掲載について</option>
            <option value="case">事例掲載について</option>
            <option value="other">その他</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-2">
            お問い合わせ内容 <span class="text-red-500">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows={6}
            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-blue-600 text-white py-3 px-6 rounded-lg font-medium hover:bg-blue-700 transition-colors"
        >
          送信する
        </button>
      </form>

      <div class="mt-8 text-center">
        <p class="text-sm text-gray-500">
          または、マッチングフォームからもお問い合わせいただけます。
        </p>
        <a 
          href="/matching"
          class="inline-block mt-2 text-blue-600 hover:text-blue-800 font-medium"
        >
          マッチングフォームへ →
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
