---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CaseFilter from '@/components/islands/CaseFilter.tsx';
import { getCollection } from 'astro:content';

const allCases = await getCollection('cases');

// Islandコンポーネントに渡すためシリアライズ可能なデータに変換
const casesData = allCases.map(c => ({
  slug: c.id,
  title: c.data.title,
  industry: c.data.industry,
  domain: c.data.domain,
  company_size: c.data.company_size,
  metric_value: c.data.metric_value,
  metric_unit: c.data.metric_unit,
  excerpt: c.data.excerpt,
  date: c.data.date.toISOString(),
  problem_tags: c.data.problem_tags,
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AIケースラボ',
  url: 'https://ai.matchagent.workers.dev',
  description: '9業種のAI導入事例を検索・比較できるデータベースです。業種・ドメイン・導入効果でフィルタリングして、あなたのビジネスに最適な事例を見つけられます。',
};
---

<BaseLayout
  title="AI導入事例一覧"
  description="9業種のAI導入事例を検索・比較できるデータベースです。業種・ドメイン・導入効果でフィルタリングして、あなたのビジネスに最適な事例を見つけられます。"
  jsonLd={jsonLd}
>
  <Header />

  <main>
    {/* ヒーローセクション背景 */}
    <div class="bg-gradient-to-b from-blue-50 via-white to-white">
      <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
        <div class="text-center mb-12">

          {/* メインタイトル */}
          <div class="flex items-center justify-center gap-3 mb-6">
            <svg class="w-8 h-8 md:w-12 md:h-12 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
            </svg>
            <h1 class="text-3xl md:text-5xl font-bold tracking-wide leading-tight bg-gradient-to-r from-blue-700 to-blue-400 bg-clip-text text-transparent">
              AI導入事例リスト
            </h1>
          </div>

          {/* 説明文 */}
          <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
            業種や領域、効果で絞り込んで、<br class="hidden sm:block"/>
            あなたのビジネスに最適な事例を見つけられます。
          </p>

          {/* 統計カード */}
          <div class="flex flex-wrap justify-center gap-4 md:gap-8">
            <div class="bg-white rounded-xl px-6 py-4 shadow-md border border-gray-100">
              <div class="text-3xl md:text-4xl font-bold text-blue-600">9</div>
              <div class="text-sm text-gray-500 mt-1">業種</div>
            </div>
            <div class="bg-white rounded-xl px-6 py-4 shadow-md border border-gray-100">
              <div class="text-3xl md:text-4xl font-bold text-blue-600">{allCases.length}+</div>
              <div class="text-sm text-gray-500 mt-1">導入事例</div>
            </div>
            <div class="bg-white rounded-xl px-6 py-4 shadow-md border border-gray-100">
              <div class="text-3xl md:text-4xl font-bold text-blue-600">7</div>
              <div class="text-sm text-gray-500 mt-1">業務領域</div>
            </div>
          </div>
        </div>

        <CaseFilter cases={casesData} client:only="react" />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
