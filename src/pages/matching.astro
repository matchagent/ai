---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MatchingForm from '../components/islands/MatchingForm.tsx';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'AI開発パートナーマッチング',
  description: 'AI導入を検討中の企業向け。要件を入力するだけで、最適なAI開発パートナーをAIがご提案します。',
};
---

<BaseLayout 
  title="パートナーマッチング" 
  description="AI導入を検討中の企業向け。要件を入力するだけで、最適なAI開発パートナーをAIがご提案します。"
  jsonLd={jsonLd}
>
  <Header />
  
  <main class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          AI開発パートナーマッチング
        </h1>
        <p class="text-gray-600 max-w-2xl mx-auto">
          あなたの業種、課題、予算を入力するだけで、
          AIが最適な開発パートナーを選定します。
        </p>
      </div>

      <div class="bg-white p-8 rounded-xl border border-gray-200 shadow-sm">
        <MatchingForm client:only="react" />
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="text-center p-6">
          <div class="text-3xl mb-3">📝</div>
          <h3 class="font-bold text-gray-900 mb-2">1. 要件を入力</h3>
          <p class="text-sm text-gray-600">
            業種、解決したい課題、予算、企業規模を入力します。
          </p>
        </div>
        <div class="text-center p-6">
          <div class="text-3xl mb-3">🤖</div>
          <h3 class="font-bold text-gray-900 mb-2">2. AIがマッチング</h3>
          <p class="text-sm text-gray-600">
            Claude APIが最適なパートナーを選定し、推薦理由を生成します。
          </p>
        </div>
        <div class="text-center p-6">
          <div class="text-3xl mb-3">🤝</div>
          <h3 class="font-bold text-gray-900 mb-2">3. パートナーと相談</h3>
          <p class="text-sm text-gray-600">
            マッチングされたパートナーと直接やり取りを開始します。
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-sm text-gray-500">
          ※マッチングサービスは無料です。パートナーとの契約は直接行っていただきます。
        </p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
