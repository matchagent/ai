---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import IndustryBadge from '../../components/case/IndustryBadge.astro';
import CaseMetric from '../../components/case/CaseMetric.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map(caseItem => ({
    params: { slug: caseItem.id },
    props: { caseItem },
  }));
}

const { caseItem } = Astro.props;
const { Content } = await render(caseItem);
const { data } = caseItem;

const industryLabels: Record<string, string> = {
  manufacturing: '製造業',
  retail: '小売・EC業',
  logistics: '物流・運輸',
  construction: '建設業',
  legal: '士業',
  food: '飲食業',
  hotel: '宿泊業',
  realestate: '不動産業',
  entertainment: '娯楽業',
};

const domainLabels: Record<string, string> = {
  sales: '営業',
  production: '生産・製造',
  hr: '人事',
  accounting: '会計',
  customer_support: 'カスタマーサポート',
  logistics: '物流',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.excerpt,
  datePublished: data.date.toISOString(),
  articleSection: industryLabels[data.industry],
  about: {
    '@type': 'Thing',
    name: `${industryLabels[data.industry]}におけるAI導入`,
  },
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'ホーム',
      item: 'https://ai.matchagent.workers.dev',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: '導入事例',
      item: 'https://ai.matchagent.workers.dev/cases',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: data.title,
      item: `https://ai.matchagent.workers.dev/cases/${caseItem.id}`,
    },
  ],
};
---

<BaseLayout 
  title={data.title}
  description={data.excerpt}
  type="article"
  jsonLd={[jsonLd, breadcrumbJsonLd]}
>
  <Header />
  
  <main class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-blue-600">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/cases" class="hover:text-blue-600">導入事例</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{data.title}</span>
      </nav>

      <article>
        <!-- Header -->
        <header class="mb-8">
          <div class="flex flex-wrap items-center gap-3 mb-4">
            <IndustryBadge industry={data.industry} />
            <span class="text-sm text-gray-500">
              {domainLabels[data.domain]}
            </span>
            {data.is_sponsored && (
              <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded-full">
                スポンサー事例
              </span>
            )}
          </div>
          
          <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
            {data.title}
          </h1>
          
          <p class="text-gray-600 text-lg mb-6">
            {data.excerpt}
          </p>

          <div class="flex flex-wrap items-center gap-6 p-6 bg-gray-50 rounded-xl">
            <div>
              <div class="text-sm text-gray-500 mb-1">効果</div>
              <CaseMetric value={data.metric_value} unit={data.metric_unit} />
            </div>
            <div class="hidden md:block w-px h-12 bg-gray-200"></div>
            <div>
              <div class="text-sm text-gray-500 mb-1">企業規模</div>
              <span class="font-medium">
                {data.company_size === 'small' && '少人数（1〜10名）'}
                {data.company_size === 'mid' && '中規模（11〜100名）'}
                {data.company_size === 'large' && '大規模（101名以上）'}
              </span>
            </div>
            <div class="hidden md:block w-px h-12 bg-gray-200"></div>
            <div>
              <div class="text-sm text-gray-500 mb-1">検証済み</div>
              <span class={`font-medium ${data.metric_verified ? 'text-green-600' : 'text-gray-400'}`}>
                {data.metric_verified ? '✓ 効果検証済み' : '検証未完了'}
              </span>
            </div>
          </div>
        </header>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-8">
          {data.problem_tags.map(tag => (
            <span class="text-sm bg-blue-50 text-blue-700 px-3 py-1 rounded-full">
              #{tag}
            </span>
          ))}
        </div>

        <!-- Content -->
        <div class="prose prose-lg max-w-none">
          <Content />
        </div>

        <!-- Date -->
        <div class="mt-12 pt-8 border-t border-gray-200">
          <p class="text-sm text-gray-500">
            公開日: {data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
        </div>
      </article>

      <!-- CTA -->
      <div class="mt-12 p-8 bg-blue-50 rounded-xl text-center">
        <h2 class="text-xl font-bold text-gray-900 mb-4">
          この事例のような成果を出したいですか？
        </h2>
        <p class="text-gray-600 mb-6">
          同じような課題を解決できるAI開発パートナーをご紹介します。
        </p>
        <a 
          href="/matching"
          class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-medium hover:bg-blue-700 transition-colors"
        >
          パートナーを探す
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
