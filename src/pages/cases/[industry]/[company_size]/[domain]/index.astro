---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CaseFilter from '@/components/islands/CaseFilter.tsx';
import { INDUSTRY_KEYS, COMPANY_SIZE_KEYS, DOMAIN_KEYS, industryLabels, companySizeLabels, companySizeFullLabels, domainLabels } from '@/utils/caseConstants';
import { getSortedCases } from '@/utils/getCasesData';
import { getInsight } from '@/data/insights';

export async function getStaticPaths() {
  return INDUSTRY_KEYS.flatMap(industry =>
    COMPANY_SIZE_KEYS.flatMap(company_size =>
      DOMAIN_KEYS.map(domain => ({ params: { industry, company_size, domain } }))
    )
  );
}

const { industry, company_size, domain } = Astro.params;

const casesData = await getSortedCases();

const industryLabel = industryLabels[industry];
const sizeLabel = companySizeLabels[company_size];
const sizeLabelFull = companySizeFullLabels[company_size];
const domainLabel = domainLabels[domain];
const pageTitle = `${industryLabel}の${sizeLabel}の${domainLabel}のAI導入事例`;
const description = `${industryLabel}の${sizeLabelFull}の${domainLabel}向けのAI導入事例を掲載。`;

const insight = getInsight(industry, company_size, domain);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description,
};
---

<BaseLayout
  title={pageTitle}
  description={description}
  jsonLd={jsonLd}
>
  <Header />

  <main>
    {/* ヒーローセクション背景 */}
    <div class="bg-gradient-to-b from-blue-50 via-white to-white">
      <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
        {/* パンくず */}
        <nav class="text-sm text-gray-500 mb-8">
          <a href="/" class="hover:text-blue-600 transition-colors">ホーム</a>
          <span class="mx-2">/</span>
          <a href="/cases" class="hover:text-blue-600 transition-colors">導入事例</a>
          <span class="mx-2">/</span>
          <a href={`/cases/${industry}`} class="hover:text-blue-600 transition-colors">{industryLabel}</a>
          <span class="mx-2">/</span>
          <a href={`/cases/${industry}/${company_size}`} class="hover:text-blue-600 transition-colors">{sizeLabel}</a>
          <span class="mx-2">/</span>
          <span class="text-gray-900">{domainLabel}</span>
        </nav>

        <div class="text-center mb-12">
          {/* メインタイトル */}
          <h1 class="text-2xl md:text-3xl font-bold tracking-wide leading-tight bg-gradient-to-r from-blue-700 to-blue-500 bg-clip-text text-transparent mb-6">
            {pageTitle}
          </h1>
          {/* 説明文 */}
          <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
            {description}<br class="hidden sm:block"/>
            同業他社の成功事例から、あなたのビジネスに最適なAI活用法を見つけられます。
          </p>
        </div>

        <CaseFilter cases={casesData} initialIndustry={industry} initialCompanySize={company_size} initialDomain={domain} client:only="react" />

        {insight && (
          <div class="mt-12 bg-blue-50 border border-blue-100 rounded-2xl p-6 md:p-8">
            <h2 class="text-lg font-bold text-blue-800 mb-4">{insight.heading}</h2>
            <ol class="space-y-4">
              {insight.items.map((item) => (
                <li>
                  <p class="font-semibold text-gray-800 mb-1">{item.title}</p>
                  <p class="text-gray-600 text-sm leading-relaxed">{item.body}</p>
                </li>
              ))}
            </ol>
            {insight.footer && (
              <p class="mt-6 pt-4 border-t border-blue-200 text-sm text-blue-700 font-medium">{insight.footer}</p>
            )}
          </div>
        )}

      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
