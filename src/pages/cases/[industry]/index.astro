---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Header from '../../../components/layout/Header.astro';
import Footer from '../../../components/layout/Footer.astro';
import CaseFilter from '../../../components/islands/CaseFilter.tsx';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  // 直接配列を定義（Cloudflareビルド時のスコープ問題を回避）
  return [
    { params: { industry: 'manufacturing' } },
    { params: { industry: 'retail' } },
    { params: { industry: 'logistics' } },
    { params: { industry: 'construction' } },
    { params: { industry: 'legal' } },
    { params: { industry: 'food' } },
    { params: { industry: 'hotel' } },
    { params: { industry: 'realestate' } },
    { params: { industry: 'entertainment' } },
  ];
}

const { industry } = Astro.params;

const industryLabels: Record<string, string> = {
  manufacturing: '製造業',
  retail: '小売・EC業',
  logistics: '物流・運輸',
  construction: '建設業',
  legal: '士業',
  food: '飲食業',
  hotel: '宿泊業',
  realestate: '不動産業',
  entertainment: '娯楽業',
};

const allCases = await getCollection('cases');

const casesData = allCases.map(c => ({
  slug: c.id,
  title: c.data.title,
  industry: c.data.industry,
  domain: c.data.domain,
  company_size: c.data.company_size,
  metric_value: c.data.metric_value,
  metric_unit: c.data.metric_unit,
  excerpt: c.data.excerpt,
  date: c.data.date.toISOString(),
  problem_tags: c.data.problem_tags,
  metric_verified: c.data.metric_verified,
}));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${industryLabels[industry]}のAI導入事例`,
  description: `${industryLabels[industry]}向けのAI導入事例をご紹介。売上向上や業務効率化を実現した具体的な事例を掲載しています。`,
};
---

<BaseLayout 
  title={`${industryLabels[industry]}の導入事例`}
  description={`${industryLabels[industry]}向けのAI導入事例をご紹介。売上向上や業務効率化を実現した具体的な事例を掲載しています。`}
  jsonLd={jsonLd}
>
  <Header />
  
  <main class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-blue-600">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/cases" class="hover:text-blue-600">導入事例</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{industryLabels[industry]}</span>
      </nav>

      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          {industryLabels[industry]}のAI導入事例一覧
        </h1>
        <p class="text-gray-600 max-w-2xl mx-auto">
          {industryLabels[industry]}向けのAI導入事例を掲載。
          同業他社の成功事例から、あなたのビジネスに最適なAI活用法を見つけられます。
        </p>
      </div>

      <CaseFilter cases={casesData} initialIndustry={industry} client:only="react" />
    </div>
  </main>

  <Footer />
</BaseLayout>
