---
import BaseLayout from '../../../../../components/layout/BaseLayout.astro';
import Header from '../../../../../components/layout/Header.astro';
import Footer from '../../../../../components/layout/Footer.astro';
import CaseFilter from '../../../../../components/islands/CaseFilter.tsx';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const industries = ['manufacturing', 'retail', 'logistics', 'construction', 'legal', 'food', 'hotel', 'realestate', 'entertainment'];
  const domains = ['sales', 'marketing', 'production', 'hr', 'accounting', 'customer_support', 'logistics'];
  return industries.flatMap(industry =>
    domains.map(domain => ({ params: { industry, domain } }))
  );
}

const { industry, domain } = Astro.params;

const industryLabels: Record<string, string> = {
  manufacturing: '製造業',
  retail: '小売・EC業',
  logistics: '物流・運輸',
  construction: '建設業',
  legal: '士業',
  food: '飲食業',
  hotel: '宿泊業',
  realestate: '不動産業',
  entertainment: '娯楽業',
};

const domainLabels: Record<string, string> = {
  sales: '営業',
  marketing: 'マーケティング',
  production: '生産・製造',
  hr: '人事',
  accounting: '会計',
  customer_support: 'カスタマーサポート',
  logistics: '物流',
};

const allCases = await getCollection('cases');

const casesData = allCases.map(c => ({
  slug: c.id,
  title: c.data.title,
  industry: c.data.industry,
  domain: c.data.domain,
  company_size: c.data.company_size,
  metric_value: c.data.metric_value,
  metric_unit: c.data.metric_unit,
  excerpt: c.data.excerpt,
  date: c.data.date.toISOString(),
  problem_tags: c.data.problem_tags,
  metric_verified: c.data.metric_verified,
  is_sponsored: c.data.is_sponsored,
}));

const industryLabel = industryLabels[industry];
const domainLabel = domainLabels[domain];
const pageTitle = `${industryLabel}の${domainLabel}AI導入事例一覧`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: `${industryLabel}・${domainLabel}向けのAI導入事例をご紹介。`,
};
---

<BaseLayout
  title={pageTitle}
  description={`${industryLabel}・${domainLabel}向けのAI導入事例をご紹介。`}
  jsonLd={jsonLd}
>
  <Header />

  <main class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-blue-600">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/cases" class="hover:text-blue-600">導入事例</a>
        <span class="mx-2">/</span>
        <a href={`/cases/${industry}`} class="hover:text-blue-600">{industryLabel}</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{domainLabel}</span>
      </nav>

      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          {pageTitle}
        </h1>
        <p class="text-gray-600 max-w-2xl mx-auto">
          {industryLabel}・{domainLabel}向けのAI導入事例を掲載。
          同業他社の成功事例から、あなたのビジネスに最適なAI活用法を見つけられます。
        </p>
      </div>

      <CaseFilter cases={casesData} initialIndustry={industry} initialDomain={domain} client:only="react" />
    </div>
  </main>

  <Footer />
</BaseLayout>
