---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CaseFilter from '@/components/islands/CaseFilter.tsx';
import { INDUSTRY_KEYS, DOMAIN_KEYS, industryLabels, domainLabels } from '@/utils/caseConstants';
import { getSortedCases } from '@/utils/getCasesData';

export async function getStaticPaths() {
  const cases = await getSortedCases();
  const existing = new Set(cases.map(c => `${c.industry}-${c.domain}`));
  return INDUSTRY_KEYS.flatMap(industry =>
    DOMAIN_KEYS.filter(domain => existing.has(`${industry}-${domain}`))
      .map(domain => ({ params: { industry, domain } }))
  );
}

const { industry, domain } = Astro.params;

const casesData = await getSortedCases();

// フィルタリングして件数を確認
const filteredCases = casesData.filter(c => c.industry === industry && c.domain === domain);

const industryLabel = industryLabels[industry];
const domainLabel = domainLabels[domain];
const pageTitle = `${industryLabel}の${domainLabel}のAI導入事例`;
const description = `${industryLabel}の${domainLabel}向けのAI導入事例を掲載。`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description,
  url: `https://ai.matchagent.workers.dev/cases/${industry}/domain/${domain}/`,
  isPartOf: {
    '@type': 'WebSite',
    name: 'AIケースラボ',
    url: 'https://ai.matchagent.workers.dev',
  },
};
---

<BaseLayout
  title={pageTitle}
  description={description}
  jsonLd={jsonLd}
>
  {filteredCases.length === 0 && (
    <meta slot="head" name="robots" content="noindex, follow" />
  )}
  <Header />

  <main>
    {/* ヒーローセクション背景 */}
    <div class="bg-gradient-to-b from-blue-50 via-white to-white">
      <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
        {/* パンくず */}
        <nav class="text-sm text-gray-500 mb-8">
          <a href="/" class="hover:text-blue-600 transition-colors">ホーム</a>
          <span class="mx-2">/</span>
          <a href="/cases" class="hover:text-blue-600 transition-colors">導入事例</a>
          <span class="mx-2">/</span>
          <a href={`/cases/${industry}`} class="hover:text-blue-600 transition-colors">{industryLabel}</a>
          <span class="mx-2">/</span>
          <span class="text-gray-900">{domainLabel}</span>
        </nav>

        <div class="text-center mb-12">
          {/* メインタイトル */}
          <h1 class="text-2xl md:text-3xl font-bold tracking-wide leading-tight bg-gradient-to-r from-blue-700 to-blue-500 bg-clip-text text-transparent mb-6">
            {pageTitle}
          </h1>

          {/* 説明文 */}
          <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
            {description}<br class="hidden sm:block"/>
            同業他社の成功事例から、あなたのビジネスに最適なAI活用法を見つけられます。
          </p>
        </div>

        <CaseFilter cases={casesData} initialIndustry={industry} initialDomain={domain} client:only="react" />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
