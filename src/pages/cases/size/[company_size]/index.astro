---
import BaseLayout from '../../../../components/layout/BaseLayout.astro';
import Header from '../../../../components/layout/Header.astro';
import Footer from '../../../../components/layout/Footer.astro';
import CaseFilter from '../../../../components/islands/CaseFilter.tsx';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    { params: { company_size: 'small' } },
    { params: { company_size: 'mid' } },
    { params: { company_size: 'large' } },
  ];
}

const { company_size } = Astro.params;

const companySizeLabels: Record<string, string> = {
  small: '少人数（1〜10名）',
  mid: '中規模（11〜100名）',
  large: '大規模（101名以上）',
};

const allCases = await getCollection('cases');

const casesData = allCases.map(c => ({
  slug: c.id,
  title: c.data.title,
  industry: c.data.industry,
  domain: c.data.domain,
  company_size: c.data.company_size,
  metric_value: c.data.metric_value,
  metric_unit: c.data.metric_unit,
  excerpt: c.data.excerpt,
  date: c.data.date.toISOString(),
  problem_tags: c.data.problem_tags,
  metric_verified: c.data.metric_verified,
}));

const sizeLabel = companySizeLabels[company_size];
const pageTitle = `${sizeLabel}のAI導入事例一覧`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: `${sizeLabel}向けのAI導入事例をご紹介。`,
};
---

<BaseLayout
  title={pageTitle}
  description={`${sizeLabel}向けのAI導入事例をご紹介。`}
  jsonLd={jsonLd}
>
  <Header />

  <main class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <nav class="text-sm text-gray-500 mb-6">
        <a href="/" class="hover:text-blue-600">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/cases" class="hover:text-blue-600">導入事例</a>
        <span class="mx-2">/</span>
        <span class="text-gray-900">{sizeLabel}</span>
      </nav>

      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          {pageTitle}
        </h1>
        <p class="text-gray-600 max-w-2xl mx-auto">
          {sizeLabel}向けのAI導入事例を掲載。
          同規模の企業の成功事例から、あなたのビジネスに最適なAI活用法を見つけられます。
        </p>
      </div>

      <CaseFilter cases={casesData} initialCompanySize={company_size} client:only="react" />
    </div>
  </main>

  <Footer />
</BaseLayout>
