---
import BaseLayout from '../../../../../components/layout/BaseLayout.astro';
import Header from '../../../../../components/layout/Header.astro';
import Footer from '../../../../../components/layout/Footer.astro';
import CaseFilter from '../../../../../components/islands/CaseFilter.tsx';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const companySizes = ['small', 'mid', 'large'];
  const domains = ['sales', 'marketing', 'production', 'hr', 'accounting', 'customer_support', 'logistics'];
  return companySizes.flatMap(company_size =>
    domains.map(domain => ({ params: { company_size, domain } }))
  );
}

const { company_size, domain } = Astro.params;

const companySizeLabels: Record<string, string> = {
  small: '少人数（1〜10名）',
  mid: '中規模（11〜100名）',
  large: '大企業（101名以上）',
};

const domainLabels: Record<string, string> = {
  sales: '営業',
  marketing: 'マーケティング',
  production: '生産・製造',
  hr: '人事',
  accounting: '会計',
  customer_support: 'カスタマーサポート',
  logistics: '物流',
};

const allCases = await getCollection('cases');
const casesData = allCases.map(c => ({
  slug: c.id,
  title: c.data.title,
  industry: c.data.industry,
  domain: c.data.domain,
  company_size: c.data.company_size,
  metric_value: c.data.metric_value ?? 0,
  metric_unit: c.data.metric_unit ?? '',
  excerpt: c.data.excerpt,
  date: c.data.date.toISOString(),
  problem_tags: c.data.problem_tags ?? [],
  metric_verified: c.data.metric_verified,
}));

const sizeLabel = companySizeLabels[company_size];
const domainLabel = domainLabels[domain];
const pageTitle = `${sizeLabel.replace(/（.*）/, '')}・${domainLabel}のAI導入事例`;
const description = `${sizeLabel}・${domainLabel}向けのAI導入事例を掲載。`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description,
};
---

<BaseLayout
  title={pageTitle}
  description={description}
  jsonLd={jsonLd}
>
  <Header />

  <main>
    {/* ヒーローセクション背景 */}
    <div class="bg-gradient-to-b from-blue-50 via-white to-white">
      <div class="max-w-6xl mx-auto px-4 py-12 md:py-16">
        {/* パンくず */}
        <nav class="text-sm text-gray-500 mb-8">
          <a href="/" class="hover:text-blue-600 transition-colors">ホーム</a>
          <span class="mx-2">/</span>
          <a href="/cases" class="hover:text-blue-600 transition-colors">導入事例</a>
          <span class="mx-2">/</span>
          <a href={`/cases/size/${company_size}`} class="hover:text-blue-600 transition-colors">{sizeLabel.replace(/（.*）/, '')}</a>
          <span class="mx-2">/</span>
          <span class="text-gray-900">{domainLabel}</span>
        </nav>

        <div class="text-center mb-12">
          {/* メインタイトル */}
          <h1 class="text-2xl md:text-3xl font-bold tracking-wide leading-tight bg-gradient-to-r from-blue-700 to-blue-500 bg-clip-text text-transparent mb-6">
            {pageTitle}
          </h1>

          {/* 説明文 */}
          <p class="text-lg text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
            {description}<br class="hidden sm:block"/>
            同規模の企業の成功事例から、あなたのビジネスに最適なAI活用法を見つけられます。
          </p>
        </div>

        <CaseFilter cases={casesData} initialCompanySize={company_size} initialDomain={domain} client:only="react" />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
