---
import { industryLabels, industryBadgeColors } from '@/utils/caseConstants';

interface Props {
  industry: string;
}

const { industry } = Astro.props;

const label = industryLabels[industry] || industry;
const colorClass = industryBadgeColors[industry] || 'bg-gray-100 text-gray-800';
---

<span class={`inline-block text-xs font-medium px-2.5 py-0.5 rounded ${colorClass}`}>
  {label}
</span>
