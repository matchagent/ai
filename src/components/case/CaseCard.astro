---
/**
 * CaseCard Astro コンポーネント
 * 
 * このコンポーネントは React の CaseCard.tsx をラップしています。
 * Astro ページから使用する場合はこちらを使い、
 * クライアントサイドでのフィルタリングには islands/CaseFilter.tsx を使います。
 */
import type { CollectionEntry } from 'astro:content';
import CaseCardReact from '@/components/islands/CaseCard';

interface Props {
  case: CollectionEntry<'cases'>;
}

const { case: caseItem } = Astro.props;

// CollectionEntry から Case 型へ変換
const caseData = {
  slug: caseItem.id,
  title: caseItem.data.title,
  industry: caseItem.data.industry,
  domain: caseItem.data.domain,
  company_size: caseItem.data.company_size,
  metric_value: caseItem.data.metric_value,
  metric_unit: caseItem.data.metric_unit,
  excerpt: caseItem.data.excerpt,
  date: caseItem.data.date.toISOString(),
  problem_tags: caseItem.data.problem_tags,
  metric_verified: caseItem.data.metric_verified,
};
---

{/* 
  client:visible ディレクティブを使用して、
  カードがビューポートに入ったときにハイドレーションされるようにします。
  これにより初期ロードは高速になりつつ、インタラクティブ性も保てます。
*/}
<CaseCardReact caseItem={caseData} client:visible />
