---
import type { CollectionEntry } from 'astro:content';
import IndustryBadge from './IndustryBadge.astro';

interface Props {
  case: CollectionEntry<'cases'>;
}

const { case: caseItem } = Astro.props;
const { data, id } = caseItem;

// 業種ごとのアイコン定義
const industryIcons: Record<string, string> = {
  manufacturing: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8l-7 5V8l-7 5V4a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z"/><path d="M17 18h1"/><path d="M12 18h1"/><path d="M7 18h1"/></svg>`,
  retail: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>`,
  logistics: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="16" height="13" x="4" y="3" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/><path d="m9 9 2 2 4-4"/></svg>`,
  construction: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 22h14a2 2 0 0 0 2-2V7.5L14.5 2H6a2 2 0 0 0-2 2v4"/><path d="M14 2v6h6"/><path d="M2 15h10"/><path d="m5 12-3 3 3 3"/></svg>`,
  legal: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 7.5 8.6"/><path d="M22 22l-5.5-5.5"/></svg>`,
  food: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>`,
  hotel: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 22h20"/><path d="M4 22V9a3 3 0 0 1 3-3h10a3 3 0 0 1 3 3v13"/><path d="M9 22v-4h6v4"/><path d="M8 6h8"/><path d="M12 6v-3"/></svg>`,
  realestate: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>`,
  entertainment: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 10v3"/><path d="M6 6v11"/><path d="M10 3v18"/><path d="M14 8v7"/><path d="M18 5v13"/><path d="M22 10v3"/></svg>`,
};

// 業種ごとのグラデーション背景色
const industryGradients: Record<string, string> = {
  manufacturing: 'from-blue-500 to-blue-600',
  retail: 'from-purple-500 to-purple-600',
  logistics: 'from-orange-500 to-orange-600',
  construction: 'from-yellow-500 to-yellow-600',
  legal: 'from-red-500 to-red-600',
  food: 'from-green-500 to-green-600',
  hotel: 'from-pink-500 to-pink-600',
  realestate: 'from-indigo-500 to-indigo-600',
  entertainment: 'from-teal-500 to-teal-600',
};

// メトリクス値に応じた色
const getMetricColor = (value: number): string => {
  if (value >= 50) return 'text-green-600 bg-green-50 border-green-200';
  if (value >= 20) return 'text-blue-600 bg-blue-50 border-blue-200';
  if (value >= 10) return 'text-indigo-600 bg-indigo-50 border-indigo-200';
  return 'text-gray-600 bg-gray-50 border-gray-200';
};

const formattedValue = data.metric_value % 1 === 0 ? data.metric_value.toString() : data.metric_value.toFixed(1);
const metricColorClass = getMetricColor(data.metric_value);
const gradientClass = industryGradients[data.industry] || 'from-gray-500 to-gray-600';
const iconSvg = industryIcons[data.industry] || '';
---

<article class="group bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
  <a href={`/cases/${id}`} class="block">
    <!-- カードヘッダー: 業種カラー背景 -->
    <div class={`h-20 bg-gradient-to-r ${gradientClass} relative overflow-hidden`}>
      <!-- 背景パターン -->
      <div class="absolute inset-0 opacity-10">
        <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
          <pattern id={`pattern-${id}`} patternUnits="userSpaceOnUse" width="20" height="20">
            <circle cx="2" cy="2" r="1" fill="white"/>
          </pattern>
          <rect width="100" height="100" fill={`url(#pattern-${id})`}/>
        </svg>
      </div>
      
      <!-- アイコンと業種名 -->
      <div class="absolute bottom-0 left-0 right-0 p-4 flex items-end justify-between">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 bg-white/20 backdrop-blur-sm rounded-lg flex items-center justify-center text-white">
            <Fragment set:html={iconSvg} />
          </div>
          <IndustryBadge industry={data.industry} />
        </div>
        
        {data.is_sponsored && (
          <span class="text-xs bg-yellow-400 text-yellow-900 px-2 py-1 rounded-full font-medium shadow-sm">
            スポンサー
          </span>
        )}
      </div>
    </div>
    
    <!-- カード本文 -->
    <div class="p-5">
      <!-- タイトル -->
      <h3 class="text-lg font-bold text-gray-900 mb-2 line-clamp-2 group-hover:text-blue-600 transition-colors">
        {data.title}
      </h3>
      
      <!-- 概要 -->
      <p class="text-sm text-gray-600 mb-4 line-clamp-2 leading-relaxed">
        {data.excerpt}
      </p>
      
      <!-- メトリクス表示（目立たせる） -->
      <div class={`inline-flex items-center gap-2 px-4 py-2 rounded-lg border ${metricColorClass} mb-4`}>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
        </svg>
        <span class="text-2xl font-bold">+{formattedValue}</span>
        <span class="text-sm font-medium">{data.metric_unit}</span>
        {data.metric_verified && (
          <svg class="w-4 h-4 ml-1" fill="currentColor" viewBox="0 0 20 20" aria-label="検証済み">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
        )}
      </div>
      
      <!-- タグ（コンパクトに） -->
      <div class="flex flex-wrap gap-1.5 mb-3">
        {data.problem_tags.slice(0, 3).map(tag => (
          <span class="text-xs text-gray-500 bg-gray-100 px-2 py-0.5 rounded">
            {tag}
          </span>
        ))}
      </div>
      
      <!-- フッター -->
      <div class="flex items-center justify-between pt-3 border-t border-gray-100">
        <span class="text-xs text-gray-400">
          {data.date.toLocaleDateString('ja-JP')}
        </span>
        <span class="text-sm text-blue-600 font-medium flex items-center gap-1 group-hover:gap-2 transition-all">
          詳細を見る
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
