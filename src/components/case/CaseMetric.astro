---
interface Props {
  value: number;
  unit: string;
}

const { value, unit } = Astro.props;

// 値に応じて色を変える
const getColorClass = (val: number): string => {
  if (val >= 50) return 'text-green-600';
  if (val >= 20) return 'text-blue-600';
  if (val >= 10) return 'text-indigo-600';
  return 'text-gray-600';
};

getColorClass(value);
const formattedValue = value % 1 === 0 ? value.toString() : value.toFixed(1);
---

<div class="flex items-baseline gap-1">
  <span class="text-2xl font-bold {colorClass}">
    +{formattedValue}
  </span>
  <span class="text-sm text-gray-600">
    {unit}
  </span>
  {value >= 20 && (
    <span class="ml-1 text-green-500">
      <svg class="w-4 h-4 inline" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z" clip-rule="evenodd" />
      </svg>
    </span>
  )}
</div>
